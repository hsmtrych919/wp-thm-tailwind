{
  "name": "wp_npm_script",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "scss:compile": "node ./scripts/scss-compile.cjs",
    "css:concat": "node ./scripts/css-concat.cjs",
    "css:postcss": "node ./scripts/css-postcss.cjs",
    "css:build": "npm-run-all -s scss:compile css:concat css:postcss",
    "imagemin": "node ./scripts/imagemin.cjs",
    "start": "npm-run-all -p watch:css watch:templates watch:webpack watch:img watch:server",
    "watch:css": "node ./scripts/watch-css.cjs",
    "watch:templates": "onchange './**/*.php' -e 'node_modules/**' -- npm run css:build",
    "watch:img": "node ./scripts/watch-img.cjs",
    "watch:webpack": "webpack --mode=development",
    "watch:server": "node ./scripts/watch-server.cjs",
    "build": "npm-run-all -s prd:scss prd:concat prd:postcss prd:webpack",
    "prd:scss": "node ./scripts/scss-compile.cjs",
    "prd:concat": "node ./scripts/css-concat.cjs",
    "prd:postcss": "node ./scripts/css-postcss.cjs",
    "prd:webpack": "webpack --mode=production",
    "lint:css": "stylelint --fix ./**/*.scss"
  },
  "license": "ISC",
  "devDependencies": {
    "@babel/core": "^7.18.6",
    "@babel/preset-env": "^7.18.6",
    "@tailwindcss/postcss": "^4.2.1",
    "autoprefixer": "^10.4.27",
    "babel-loader": "^8.2.5",
    "browser-sync": "^2.26.14",
    "eslint": "^8.20.0",
    "eslint-config-prettier": "^8.5.0",
    "imagemin": "^7.0.1",
    "imagemin-gifsicle": "^7.0.0",
    "imagemin-keep-folder": "^5.3.2",
    "imagemin-mozjpeg": "^9.0.0",
    "imagemin-pngquant": "^9.0.0",
    "imagemin-svgo": "^8.0.0",
    "npm-run-all": "^4.1.5",
    "onchange": "^7.0.2",
    "postcss": "^8.4.14",
    "postcss-cli": "^11.0.1",
    "prettier": "^2.7.1",
    "sass": "^1.32.8",
    "stylelint": "^14.9.1",
    "stylelint-config-property-sort-order-smacss": "^8.0.0",
    "stylelint-config-recommended-scss": "^5.0.2",
    "stylelint-scss": "^4.3.0",
    "tailwindcss": "^4.2.1",
    "watch": "^1.0.2",
    "webpack": "^5.73.0",
    "webpack-cli": "^4.10.0",
    "webpack-stream": "^5.2.1"
  },
  "browserslist": [
    "last 2 versions"
  ],
  "dependencies": {
    "@prettier/plugin-php": "^0.19.2",
    "animejs": "^3.2.1",
    "gsap": "^3.12.4",
    "micromodal": "^0.4.10",
    "scroll-hint": "^1.2.5",
    "smooth-scroll": "^16.1.3",
    "swiper": "^8.4.5"
  }
}
